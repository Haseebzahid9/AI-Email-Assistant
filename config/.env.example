# ─── LLM Provider ────────────────────────────────────────────────────────────
# Claude (Anthropic) — recommended
LLM_API_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-5

# OpenAI-compatible alternative (uncomment to switch)
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ─── Gmail ────────────────────────────────────────────────────────────────────
# Configure inside n8n Credentials (OAuth2 → Google Gmail API)
# N8N_GMAIL_CREDENTIAL_NAME=Gmail OAuth2

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Sheet tab name (must match exactly)
GOOGLE_SHEET_TAB=EmailLog

# Configure inside n8n Credentials (OAuth2 → Google Sheets API)
# N8N_SHEETS_CREDENTIAL_NAME=Google Sheets OAuth2

# ─── Slack ────────────────────────────────────────────────────────────────────
# Slack channel name for urgent alerts (include the # prefix)
SLACK_CHANNEL=#email-alerts

# Configure inside n8n Credentials (Slack OAuth2 API)
# N8N_SLACK_CREDENTIAL_NAME=Slack OAuth2

# ─── n8n Instance (self-hosted only) ─────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
